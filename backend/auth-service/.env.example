SERVICE_NAME=library-auth-service
SERVICE_ENV=development
SERVICE_PORT=:8081
ALLOWED_ORIGIN=http://localhost:3000

DATABASE_DSN=auth:auth_password@tcp(localhost:3306)/auth?parseTime=true&loc=UTC&charset=utf8mb4
DATABASE_MIGRATION_URL=mysql://auth:auth_password@tcp(localhost:3306)/auth
DATABASE_MAX_OPEN_CONNS=20
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=30m
DATABASE_CONN_MAX_IDLE_TIME=5m

BCRYPT_COST=12
SESSION_TTL=24h
SESSION_COOKIE_NAME=lms_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=15m

OAUTH_ISSUER=http://localhost:8000
LOGIN_URL=http://localhost:3000/login
OAUTH_CODE_TTL=5m
OAUTH_ACCESS_TOKEN_TTL=15m
OAUTH_REFRESH_TOKEN_TTL=168h
OAUTH_JWT_SIGNING_KEY=local-development-only-jwt-signing-key
OAUTH_CLIENT_SCOPES=loans:borrow:self loans:return:self transactions:read:self books:read transactions:read:any loans:return:any fines:manage books:manage identities:create book-stock:read book-stock:reserve book-stock:release
