SERVICE_NAME=library-user-service
SERVICE_ENV=development
SERVICE_PORT=:8082
ALLOWED_ORIGIN=http://localhost:3000
TRUSTED_PROXIES=

DATABASE_DSN=users:users_password@tcp(127.0.0.1:3307)/users?parseTime=true&loc=UTC&charset=utf8mb4
DATABASE_MIGRATION_URL=mysql://users:users_password@tcp(127.0.0.1:3307)/users
DATABASE_MAX_OPEN_CONNS=20
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=30m
DATABASE_CONN_MAX_IDLE_TIME=5m

AUTH_SERVICE_URL=http://127.0.0.1:8081
AUTH_CLIENT_ID=user-service
AUTH_CLIENT_SECRET=local-development-only-user-service-secret
AUTH_SCOPE=identities:create
AUTH_REQUEST_TIMEOUT=5s
AUTH_REQUEST_ATTEMPTS=3

RABBITMQ_URL=amqp://library:library_password@127.0.0.1:5672/
RABBITMQ_EXCHANGE=library.events
RABBITMQ_ROUTING_KEY=user.registered.v1
RABBITMQ_QUEUE=library.user-registered.v1
RABBITMQ_CONFIRM_TIMEOUT=5s

OUTBOX_BATCH_SIZE=50
OUTBOX_LEASE=30s
OUTBOX_POLL_INTERVAL=500ms
OUTBOX_BASE_RETRY=1s
OUTBOX_MAX_RETRY=1m

REGISTRATION_RATE_LIMIT_MAX=10
REGISTRATION_RATE_LIMIT_WINDOW=15m
