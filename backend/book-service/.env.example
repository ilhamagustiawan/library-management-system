SERVICE_NAME=library-book-service
SERVICE_ENV=development
SERVICE_PORT=:8083
ALLOWED_ORIGIN=http://localhost:3000
TRUSTED_PROXIES=172.30.0.2

DATABASE_DSN=book:book_password@tcp(localhost:3308)/book?parseTime=true&loc=UTC&charset=utf8mb4
DATABASE_MIGRATION_URL=mysql://book:book_password@tcp(localhost:3308)/book
DATABASE_MAX_OPEN_CONNS=20
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=30m
DATABASE_CONN_MAX_IDLE_TIME=5m

AUTH_INTROSPECTION_URL=http://localhost:8081/oauth/introspect
INTROSPECTION_CLIENT_ID=book-service
INTROSPECTION_CLIENT_SECRET=local-development-only-book-introspection-secret
AUTH_INTROSPECTION_TIMEOUT=2s
OAUTH_ISSUER=http://localhost:8081
OAUTH_AUDIENCE=book-service
TRANSACTION_SERVICE_CLIENT_ID=transaction-service

RABBITMQ_URL=amqp://library:library_password@localhost:5672/
