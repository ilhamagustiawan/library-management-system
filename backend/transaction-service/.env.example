SERVICE_ENV=development
SERVICE_PORT=:8084
ALLOWED_ORIGIN=http://localhost:3000
TRUSTED_PROXIES=127.0.0.1 ::1
DATABASE_DSN=transactions:transactions_password@tcp(localhost:3309)/transactions?parseTime=true&loc=UTC&charset=utf8mb4
DATABASE_MIGRATION_URL=mysql://transactions:transactions_password@tcp(localhost:3309)/transactions
AUTH_TOKEN_URL=http://localhost:8081/oauth/token
BOOK_SERVICE_URL=http://localhost:8083
BOOK_SERVICE_CLIENT_ID=transaction-service
BOOK_SERVICE_CLIENT_SECRET=local-development-only-transaction-service-secret
RABBITMQ_URL=amqp://library:library_password@localhost:5672/
LOAN_TERM=168h
FINE_DAILY_RATE_MINOR=5000
STOCK_ACK_TIMEOUT=5s
