{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Catalog, inventory, and atomic stock reservation service.",
        "title": "Library Management Book API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/api/v1/books": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Books"
                ],
                "summary": "List books",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Title, author, or ISBN search",
                        "name": "q",
                        "in": "query"
                    },
                    {
                        "type": "boolean",
                        "description": "Only books with available stock",
                        "name": "availableOnly",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 1,
                        "description": "Page number",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "maximum": 100,
                        "type": "integer",
                        "default": 20,
                        "description": "Page size",
                        "name": "pageSize",
                        "in": "query"
                    },
                    {
                        "enum": [
                            "title",
                            "author",
                            "createdAt"
                        ],
                        "type": "string",
                        "description": "Sort field",
                        "name": "sortBy",
                        "in": "query"
                    },
                    {
                        "enum": [
                            "asc",
                            "desc"
                        ],
                        "type": "string",
                        "description": "Sort order",
                        "name": "sortOrder",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.BookPageSuccess"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "Unprocessable Entity",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Books"
                ],
                "summary": "Create book",
                "parameters": [
                    {
                        "description": "Book data",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/request.CreateBook"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/response.BookSuccess"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "Unprocessable Entity",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/books/{id}": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Books"
                ],
                "summary": "Get book",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Book UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.BookSuccess"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                }
            },
            "delete": {
                "tags": [
                    "Books"
                ],
                "summary": "Archive book",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Book UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                }
            },
            "patch": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Books"
                ],
                "summary": "Update book",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Book UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Partial book data",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/request.UpdateBook"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.BookSuccess"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "Unprocessable Entity",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/health/liveness": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Liveness",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.Health"
                        }
                    }
                }
            }
        },
        "/health/readiness": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Readiness",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.Health"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/internal/v1/books/{id}/reservations/{transactionId}": {
            "put": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Internal stock"
                ],
                "summary": "Reserve book stock",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Book UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Transaction UUID",
                        "name": "transactionId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Existing active reservation",
                        "schema": {
                            "$ref": "#/definitions/response.ReservationSuccess"
                        }
                    },
                    "201": {
                        "description": "Reservation created",
                        "schema": {
                            "$ref": "#/definitions/response.ReservationSuccess"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                }
            },
            "delete": {
                "tags": [
                    "Internal stock"
                ],
                "summary": "Release book stock",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Book UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Transaction UUID",
                        "name": "transactionId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/internal/v1/books/{id}/stock": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Internal stock"
                ],
                "summary": "Read internal book stock",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Book UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.StockSuccess"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "entity.Reservation": {
            "type": "object",
            "properties": {
                "bookId": {
                    "type": "string"
                },
                "createdAt": {
                    "type": "string"
                },
                "releasedAt": {
                    "type": "string"
                },
                "status": {
                    "$ref": "#/definitions/entity.ReservationStatus"
                },
                "transactionId": {
                    "type": "string"
                }
            }
        },
        "entity.ReservationStatus": {
            "type": "string",
            "enum": [
                "active",
                "released"
            ],
            "x-enum-varnames": [
                "ReservationActive",
                "ReservationReleased"
            ]
        },
        "entity.Stock": {
            "type": "object",
            "properties": {
                "availableCopies": {
                    "type": "integer"
                },
                "bookId": {
                    "type": "string"
                },
                "totalCopies": {
                    "type": "integer"
                }
            }
        },
        "request.CreateBook": {
            "type": "object",
            "required": [
                "author",
                "isbn",
                "title",
                "totalCopies"
            ],
            "properties": {
                "author": {
                    "type": "string",
                    "maxLength": 255,
                    "example": "Robert C. Martin"
                },
                "coverUrl": {
                    "type": "string",
                    "maxLength": 512,
                    "example": "https://covers.openlibrary.org/b/id/10521270-M.jpg"
                },
                "description": {
                    "type": "string",
                    "maxLength": 5000,
                    "example": "A handbook of agile software craftsmanship."
                },
                "isbn": {
                    "type": "string",
                    "maxLength": 32,
                    "example": "9780132350884"
                },
                "publicationYear": {
                    "type": "integer",
                    "minimum": 1000,
                    "example": 2008
                },
                "title": {
                    "type": "string",
                    "maxLength": 255,
                    "example": "Clean Code"
                },
                "totalCopies": {
                    "type": "integer",
                    "minimum": 1,
                    "example": 3
                }
            }
        },
        "request.UpdateBook": {
            "type": "object",
            "properties": {
                "author": {
                    "type": "string",
                    "example": "Robert C. Martin"
                },
                "coverUrl": {
                    "type": "string",
                    "example": "https://covers.openlibrary.org/b/id/10521270-M.jpg"
                },
                "description": {
                    "type": "string",
                    "example": "Updated description"
                },
                "isbn": {
                    "type": "string",
                    "example": "9780132350884"
                },
                "publicationYear": {
                    "type": "integer",
                    "example": 2009
                },
                "title": {
                    "type": "string",
                    "example": "Clean Code"
                },
                "totalCopies": {
                    "type": "integer",
                    "example": 4
                }
            }
        },
        "response.Book": {
            "type": "object",
            "properties": {
                "author": {
                    "type": "string",
                    "example": "Robert C. Martin"
                },
                "availableCopies": {
                    "type": "integer",
                    "example": 2
                },
                "coverUrl": {
                    "type": "string",
                    "example": "https://covers.openlibrary.org/b/id/10521270-M.jpg"
                },
                "createdAt": {
                    "type": "string",
                    "example": "2026-07-19T08:00:00Z"
                },
                "description": {
                    "type": "string",
                    "example": "A handbook of agile software craftsmanship."
                },
                "id": {
                    "type": "string",
                    "example": "f81d4fae-7dec-41d0-a765-00a0c91e6bf6"
                },
                "isbn": {
                    "type": "string",
                    "example": "9780132350884"
                },
                "publicationYear": {
                    "type": "integer",
                    "example": 2008
                },
                "title": {
                    "type": "string",
                    "example": "Clean Code"
                },
                "totalCopies": {
                    "type": "integer",
                    "example": 3
                },
                "updatedAt": {
                    "type": "string",
                    "example": "2026-07-19T08:00:00Z"
                }
            }
        },
        "response.BookPage": {
            "type": "object",
            "properties": {
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/response.Book"
                    }
                },
                "pagination": {
                    "$ref": "#/definitions/response.Pagination"
                }
            }
        },
        "response.BookPageSuccess": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "example": "LMS-200000"
                },
                "data": {
                    "$ref": "#/definitions/response.BookPage"
                }
            }
        },
        "response.BookSuccess": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "example": "LMS-200000"
                },
                "data": {
                    "$ref": "#/definitions/response.Book"
                }
            }
        },
        "response.ErrorResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "example": "LMS-422001"
                },
                "data": {},
                "message": {
                    "type": "string",
                    "example": "invalid request data"
                }
            }
        },
        "response.Health": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string",
                    "example": "ok"
                }
            }
        },
        "response.Pagination": {
            "type": "object",
            "properties": {
                "page": {
                    "type": "integer",
                    "example": 1
                },
                "pageSize": {
                    "type": "integer",
                    "example": 20
                },
                "totalItems": {
                    "type": "integer",
                    "example": 42
                },
                "totalPages": {
                    "type": "integer",
                    "example": 3
                }
            }
        },
        "response.ReservationSuccess": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "example": "LMS-200000"
                },
                "data": {
                    "$ref": "#/definitions/entity.Reservation"
                }
            }
        },
        "response.StockSuccess": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "example": "LMS-200000"
                },
                "data": {
                    "$ref": "#/definitions/entity.Stock"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}